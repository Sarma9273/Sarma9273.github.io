---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import LiveBlogGrid from '../components/LiveBlogGrid.astro';
import Icon from '../components/Icon.astro';
import SocialLinks from '../components/SocialLinks.astro';
import heroImage from '../assets/images/guru-charan-hero.webp';
import aboutImage from '../assets/images/guru-charan-about.webp';
import { focusAreas, education, experience } from '../data/profile';

const projects = (await getCollection('projects')).sort((a,b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0,6);
const blogs = (await getCollection('blogs', ({ data }) => !data.draft)).sort((a,b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const featuredBlogs = blogs.filter((post) => post.data.featured).slice(0,3);
---

<BaseLayout>
  <section class="hero section-shell personal-hero">
    <div class="hero-orb hero-orb-one" aria-hidden="true"></div>
    <div class="hero-orb hero-orb-two" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy reveal" data-reveal>
        <span class="availability"><span></span> Open to meaningful cybersecurity and AI opportunities</span>
        <p class="hero-kicker">Hi, I’m Guru Charan 👋</p>
        <h1>I’m learning how AI can make cybersecurity calmer, faster and more explainable.</h1>
        <p class="hero-description">
          I am an M.Tech AI&DSE student at IIT Patna, a cybersecurity learner,
          computer teacher and hands-on builder. This portfolio is my public
          notebook—projects I am proud of, mistakes I learned from and ideas I am
          still turning into working systems.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/projects/">See what I’m building <Icon name="arrow" size={18} /></a>
          <a class="button button-secondary" href="/blogs/">Follow my learning notes</a>
          <a class="button button-quiet" href="/contact/"><Icon name="mail" size={18} /> Say hello</a>
        </div>
        <SocialLinks compact={false} />
        <div class="personal-signature" aria-label="Personal focus">
          <span>Currently:</span>
          <strong data-rotating-focus>building CyberGPT</strong>
        </div>
      </div>

      <div class="hero-visual reveal" data-reveal>
        <div class="portrait-frame personal-portrait" data-tilt>
          <Image
            src={heroImage}
            alt="Guru Charan Mavuduru wearing a navy blazer"
            widths={[480, 720, 960]}
            sizes="(max-width: 900px) 78vw, 38vw"
            loading="eager"
            fetchpriority="high"
          />
          <div class="portrait-glow"></div>
          <div class="portrait-note">
            <span class="portrait-note-label">My current chapter</span>
            <strong>M.Tech AI&DSE · IIT Patna</strong>
            <small>Cybersecurity, applied AI and learning in public</small>
          </div>
        </div>
        <div class="floating-card floating-card-a"><strong>Building</strong><span>CyberGPT · SOC automation</span></div>
        <div class="floating-card floating-card-b"><strong>Learning</strong><span>AI&DSE · security engineering</span></div>
      </div>
    </div>

    <div class="container chapter-strip reveal" data-reveal aria-label="Current work and learning">
      <div><span>01</span><strong>AI for security</strong><p>Designing tools that support analysts without hiding the reasoning.</p></div>
      <div><span>02</span><strong>Practical SOC work</strong><p>Building labs, collecting evidence and understanding attacker behaviour.</p></div>
      <div><span>03</span><strong>Teaching technology</strong><p>Turning difficult concepts into useful, beginner-friendly learning experiences.</p></div>
      <div><span>04</span><strong>Documenting honestly</strong><p>Sharing the process, failures, fixes and next steps—not only final screenshots.</p></div>
    </div>
  </section>

  <section class="section personal-intro">
    <div class="container personal-intro-grid">
      <div class="about-image reveal" data-reveal data-tilt>
        <Image
          src={aboutImage}
          alt="Guru Charan Mavuduru in an earlier portrait"
          widths={[430, 650, 850]}
          sizes="(max-width: 820px) 88vw, 34vw"
        />
      </div>
      <div class="personal-story reveal" data-reveal>
        <span class="eyebrow">A little about me</span>
        <h2>I did not begin in cybersecurity. I kept following the problems that made me curious.</h2>
        <p>
          My journey started in Electrical and Electronics Engineering, moved
          through web development and technical training, and gradually found a
          home in security operations and applied AI. That mixed background is
          now one of my strengths: I enjoy understanding complete systems, not
          only isolated tools.
        </p>
        <blockquote>
          “I want my work to be useful enough to solve a real problem and clear
          enough that another learner can understand how it was built.”
        </blockquote>
        <div class="story-actions">
          <a class="text-link" href="/about/">Read my full journey <Icon name="arrow" size={17} /></a>
          <a class="text-link" href="/experience/">See where I have worked <Icon name="arrow" size={17} /></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-muted personal-section">
    <div class="container">
      <SectionHeading
        eyebrow="Things I care about"
        title="Four areas that keep connecting in my work"
        description="I am not trying to look like a company. I am building a career by learning deeply, making practical things and sharing the journey clearly."
      />
      <div class="focus-grid">
        {focusAreas.map((area, index) => (
          <article class="focus-card interactive-card reveal" data-reveal data-tilt style={`--card-index:${index}`}>
            <div class="focus-icon"><Icon name={area.icon} size={30} /></div>
            <span class="focus-number">0{index + 1}</span>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-row">
        <SectionHeading
          eyebrow="Projects I’m proud of"
          title="Work that shows how I think, learn and solve"
          description="Each case study includes what I attempted, how the system works, the challenges I faced and what I would improve next."
        />
        <a class="text-link section-link" href="/projects/">View every project <Icon name="arrow" size={17} /></a>
      </div>
      <div class="project-grid">
        {featuredProjects.map((project, index) => (
          <div class="reveal" data-reveal style={`--reveal-delay:${index * 55}ms`}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section now-section">
    <div class="container now-grid">
      <div class="now-copy reveal" data-reveal>
        <span class="eyebrow">What I’m doing now</span>
        <h2>This portfolio is a living record, not a finished brochure.</h2>
        <p>
          I am currently balancing postgraduate study, teaching, security
          learning and project development. Some projects are functional, some
          are research prototypes and some are still becoming clearer through
          experimentation.
        </p>
        <a class="button button-light" href="/contact/">Talk to me about an opportunity <Icon name="arrow" size={18} /></a>
      </div>
      <div class="now-list reveal" data-reveal>
        <article><span>Studying</span><strong>{education[0].qualification}</strong><small>{education[0].institution}</small></article>
        <article><span>Working as</span><strong>{experience[0].role}</strong><small>{experience[0].organisation}</small></article>
        <article><span>Building</span><strong>CyberGPT and Portfolio V3</strong><small>AI-assisted security and learning-in-public systems</small></article>
        <article><span>Exploring</span><strong>SOC automation and explainable AI</strong><small>With practical labs, documentation and feedback</small></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-row">
        <SectionHeading
          eyebrow="My learning notes"
          title="New writing can appear here directly from Google Drive"
          description="These are project journals, research explanations and practical notes. When Drive sync is enabled, newly uploaded Google Docs appear without rebuilding the GitHub repository."
        />
        <a class="text-link section-link" href="/blogs/">Open the complete notebook <Icon name="arrow" size={17} /></a>
      </div>
      <LiveBlogGrid posts={featuredBlogs} limit={3} />
    </div>
  </section>

  <section class="section section-muted">
    <div class="container cta-panel personal-cta reveal" data-reveal>
      <div>
        <span class="eyebrow">Let’s connect</span>
        <h2>Have a role, idea or problem that matches my direction?</h2>
        <p>
          I am interested in SOC Analyst, Cybersecurity Analyst, AI-for-security,
          technical education and meaningful project-collaboration opportunities.
        </p>
      </div>
      <div class="cta-actions">
        <a class="button button-primary" href="/contact/">Send me a message <Icon name="arrow" size={18} /></a>
        <a class="button button-secondary" href="/resume/">Review my resume</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const focusItems = [
        'building CyberGPT',
        'studying AI&DSE at IIT Patna',
        'improving my SOC skills',
        'teaching computer fundamentals',
        'documenting what I learn',
      ];
      const target = document.querySelector('[data-rotating-focus]');
      let index = 0;
      if (target && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        window.setInterval(() => {
          index = (index + 1) % focusItems.length;
          target.classList.add('is-changing');
          window.setTimeout(() => {
            target.textContent = focusItems[index];
            target.classList.remove('is-changing');
          }, 180);
        }, 2800);
      }
    })();
  </script>
</BaseLayout>
