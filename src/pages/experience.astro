---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { experience } from '../data/profile';
---
<BaseLayout title="Experience" description="Guru Charan Mavuduru's experience across computer education, cybersecurity training, engineering design and electrical infrastructure.">
  <section class="page-hero personal-page-hero">
    <div class="container narrow reveal" data-reveal>
      <span class="eyebrow">Where I have learned by working</span>
      <h1>Teaching, training and engineering roles that changed how I approach problems.</h1>
      <p>
        Every role added something different: patience from teaching, clarity
        from training, discipline from engineering and confidence from solving
        practical technical problems.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="experience-list">
        {experience.map((item,index) => (
          <article class="experience-item reveal" data-reveal>
            <div class="experience-index">{String(index+1).padStart(2,'0')}</div>
            <div class="experience-main">
              <div class="experience-header">
                <div>
                  <span class="eyebrow">{item.period}</span>
                  <h2>{item.role}</h2>
                  <strong>{item.organisation}</strong>
                </div>
                <span class="location"><Icon name="location" size={17} />{item.location}</span>
              </div>
              <ul>{item.highlights.map((highlight) => <li>{highlight}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container cta-panel personal-cta reveal" data-reveal>
      <div>
        <span class="eyebrow">My next chapter</span>
        <h2>I am ready to grow inside a real security operations environment.</h2>
        <p>
          My immediate goal is an entry-level SOC or cybersecurity role where I
          can investigate alerts, improve detection knowledge, learn from
          experienced analysts and contribute through disciplined documentation.
        </p>
      </div>
      <a class="button button-primary" href="/resume/">Open my resume <Icon name="arrow" size={18} /></a>
    </div>
  </section>
</BaseLayout>
