---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiveBlogGrid from '../../components/LiveBlogGrid.astro';

const posts = (await getCollection('blogs', ({data}) => !data.draft))
  .sort((a,b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout
  title="Learning Notes & Blogs"
  description="Project build logs, cybersecurity learning, applied AI notes, research explanations and practical technology articles by Guru Charan Mavuduru."
>
  <section class="page-hero personal-page-hero">
    <div class="container narrow reveal" data-reveal>
      <span class="eyebrow">My public notebook</span>
      <h1>Notes from things I am building, breaking, fixing and finally understanding.</h1>
      <p>
        This is less of a formal publication and more of a growing technical
        journal. New Google Docs can appear here automatically after the one-time
        Drive connection is configured.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <LiveBlogGrid posts={posts} filters={true} />
    </div>
  </section>
</BaseLayout>
