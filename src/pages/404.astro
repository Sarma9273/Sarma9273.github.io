---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout title="Page not found" description="The requested portfolio page could not be found." noindex={true}>
  <section class="not-found"><div class="container narrow"><span class="error-code">404</span><h1>This page is not part of the current build.</h1><p>Use the portfolio navigation or return to the homepage.</p><div class="hero-actions"><a class="button button-primary" href="/">Return home <Icon name="arrow" size={18} /></a><a class="button button-secondary" href="/projects/">Browse projects</a></div></div></section>
</BaseLayout>
